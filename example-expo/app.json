{
  "expo": {
    "name": "OnramperReactNativeExample",
    "slug": "onramper-react-native-example",
    "version": "1.0.0",
    "platforms": [
      "ios"
    ],
    "newArchEnabled": true,
    "plugins": [
      "@onramper/onramper-react-native"
    ],
    "ios": {
      "bundleIdentifier": "com.onramper.demo.react-native-expo",
      "deploymentTarget": "16.4",
      "entitlements": {
        "com.apple.developer.devicecheck.appattest-environment": "development"
      },
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true
        }
      },
      "appleTeamId": "P3JUP9FF82"
    }
  }
}
