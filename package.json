{
  "name": "@onramper/onramper-react-native",
  "version": "1.0.1",
  "description": "React Native wrapper for the Onramper iOS SDK",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/commonjs/src/index.d.ts",
  "react-native": "./src/index.ts",
  "source": "./src/index.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "src",
    "ios/*.swift",
    "ios/Frameworks/OnramperSDK.xcframework",
    "nitrogen/generated",
    "nitro.json",
    "OnramperReactNative.podspec",
    "app.plugin.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "rm -rf lib",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "nitrogen": "nitrogen && node scripts/sync-view-config.js",
    "prepare": "bob build",
    "prepack": "node scripts/check-xcframework.js",
    "verify-version": "node scripts/verify-version.js",
    "fetch-xcframework": "node scripts/fetch-xcframework.js",
    "slim-xcframework": "node scripts/slim-xcframework.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react-native",
    "expo",
    "onramper",
    "crypto",
    "onramp"
  ],
  "repository": "https://github.com/onramper/onramper-react-native",
  "author": "Onramper <engineering@onramper.com>",
  "license": "Apache-2.0",
  "homepage": "https://github.com/onramper/onramper-react-native#readme",
  "onramperSDK": {
    "checksum": "3b0ef3356d46bdda6f3dc29043e3f00a9386bfa3411ce3115f2d479044458740"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.79.0",
    "react-native-nitro-modules": ">=0.35.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@expo/config-plugins": "^10.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.0",
    "jest": "^29.7.0",
    "nitrogen": "^0.35.9",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-builder-bob": "^0.41.0",
    "react-native-nitro-modules": "^0.35.9",
    "ts-jest": "^29.4.10",
    "typescript": "~5.8.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  }
}
