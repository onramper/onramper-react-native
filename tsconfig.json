{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["dom", "esnext"],
    "jsx": "react-native",
    "module": "esnext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "noImplicitReturns": true,
    "rootDir": "."
  },
  "include": ["src"],
  "exclude": ["lib", "build", "**/__mocks__/*", "**/__tests__/*", "example", "example-bare"]
}
